<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Priscila Schilaro Santa Rosa</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,900;1,9..144,300;1,9..144,700&family=Syne:wght@400;700;800&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --pu:#7c3aed;--pu2:#a855f7;--pu3:#ddd6fe;--pu4:#f5f3ff;
  --gr:#16a34a;--gr2:#4ade80;
  --ye:#facc15;--ye2:#fef08a;
  --wh:#ffffff;--bk:#09090b;
  --fr:'Fraunces',Georgia,serif;
  --sy:'Syne',system-ui,sans-serif;
  --mo:'IBM Plex Mono',monospace;
}
html{scroll-behavior:smooth}
body{font-family:var(--sy);background:var(--bk);color:var(--wh);overflow-x:hidden;font-size:16px;line-height:1.6}
a{text-decoration:none;color:inherit}

/* ── CURSOR GLOW ── */
.cursor-glow{
  width:400px;height:400px;border-radius:50%;
  background:radial-gradient(circle,rgba(124,58,237,0.15) 0%,transparent 70%);
  position:fixed;pointer-events:none;z-index:0;
  transform:translate(-50%,-50%);transition:opacity 0.3s;
}

/* ── NAV ── */
nav{
  position:sticky;top:0;z-index:200;
  background:rgba(9,9,11,0.85);
  backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(124,58,237,0.2);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3rem;height:60px;
}
.nav-logo{font-family:var(--fr);font-style:italic;font-size:1.1rem;color:var(--wh);font-weight:300}
.nav-logo span{color:var(--pu2)}
.nav-links{display:flex;gap:0;list-style:none}
.nav-links a{
  padding:0 1.1rem;height:60px;line-height:60px;
  font-family:var(--mo);font-size:10px;letter-spacing:0.14em;
  color:rgba(255,255,255,0.45);border-left:1px solid rgba(255,255,255,0.06);
  transition:color 0.2s,background 0.2s;
}
.nav-links a:hover{color:var(--ye);background:rgba(124,58,237,0.12)}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:grid;grid-template-columns:1fr 1fr;
  position:relative;overflow:hidden;
}
#hero-canvas{
  position:absolute;inset:0;width:100%;height:100%;z-index:0;
  opacity:0.6;
}
.hero-left{
  position:relative;z-index:2;
  padding:7rem 4rem 5rem;
  display:flex;flex-direction:column;justify-content:space-between;
  border-right:1px solid rgba(124,58,237,0.25);
}
.hero-eyebrow{
  font-family:var(--mo);font-size:10px;letter-spacing:0.22em;
  color:var(--pu2);margin-bottom:2.5rem;
  display:flex;align-items:center;gap:0.8rem;
  opacity:0;animation:fadeUp 0.6s 0.2s forwards;
}
.hero-eyebrow::before{content:'';width:28px;height:1px;background:var(--pu2)}
.hero-h1{
  font-family:var(--fr);font-weight:900;
  font-size:clamp(4rem,8vw,9rem);
  line-height:0.88;letter-spacing:-0.02em;
  opacity:0;animation:fadeUp 0.8s 0.35s forwards;
}
.hero-h1 .l1{color:var(--wh)}
.hero-h1 .l2{color:var(--pu2);font-style:italic;font-weight:300}
.hero-h1 .l3{
  color:transparent;
  -webkit-text-stroke:1px rgba(168,85,247,0.5);
  font-style:italic;
}
.hero-desc{
  font-family:var(--fr);font-style:italic;font-weight:300;
  font-size:1rem;color:rgba(255,255,255,0.5);
  max-width:380px;line-height:1.9;
  border-left:2px solid var(--pu);padding-left:1rem;
  margin-top:2.5rem;
  opacity:0;animation:fadeUp 0.6s 0.55s forwards;
}
.hero-actions{
  display:flex;gap:1rem;margin-top:3rem;flex-wrap:wrap;
  opacity:0;animation:fadeUp 0.6s 0.7s forwards;
}
.btn-fill{
  background:var(--pu);color:var(--wh);
  font-family:var(--mo);font-size:10px;letter-spacing:0.14em;
  padding:0.85rem 1.8rem;border:none;cursor:pointer;
  transition:background 0.2s,transform 0.15s;display:inline-block;
}
.btn-fill:hover{background:var(--pu2);transform:translateY(-2px)}
.btn-ghost{
  background:transparent;color:rgba(255,255,255,0.6);
  font-family:var(--mo);font-size:10px;letter-spacing:0.14em;
  padding:0.85rem 1.8rem;
  border:1px solid rgba(255,255,255,0.15);cursor:pointer;
  transition:border-color 0.2s,color 0.2s;display:inline-block;
}
.btn-ghost:hover{border-color:var(--pu2);color:var(--pu2)}

/* Hero right — illustrated panel */
.hero-right{
  position:relative;z-index:2;
  padding:5rem 3rem;
  display:flex;flex-direction:column;justify-content:center;align-items:center;
  opacity:0;animation:fadeIn 1s 0.5s forwards;
}
.hero-illustration{width:100%;max-width:420px}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.in{opacity:1;transform:none}
.reveal-left{opacity:0;transform:translateX(-40px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal-left.in{opacity:1;transform:none}
.reveal-right{opacity:0;transform:translateX(40px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal-right.in{opacity:1;transform:none}

/* ── TICKER ── */
.ticker{
  background:var(--pu);padding:10px 0;overflow:hidden;white-space:nowrap;
  border-top:1px solid rgba(255,255,255,0.1);
  border-bottom:1px solid rgba(255,255,255,0.1);
}
.ticker-track{display:inline-block;animation:ticker 22s linear infinite}
.ticker-track span{
  font-family:var(--mo);font-size:11px;letter-spacing:0.18em;
  color:rgba(255,255,255,0.85);margin:0 2.5rem;
}
.ticker-track span.dot{color:var(--ye);margin:0 0.5rem}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── EDUCATION — BENTO GRID ── */
.bento{padding:6rem 3rem;background:var(--bk)}
.bento-grid{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  grid-template-rows:auto;
  gap:12px;
}
.bento-cell{
  background:#18181b;border:1px solid rgba(124,58,237,0.2);
  padding:2rem;overflow:hidden;position:relative;
  transition:border-color 0.25s,transform 0.25s;cursor:default;
}
.bento-cell:hover{border-color:var(--pu);transform:translateY(-3px)}
.bc-1{grid-column:span 4;grid-row:span 1}
.bc-2{grid-column:span 2;background:var(--pu);border-color:var(--pu)}
.bc-3{grid-column:span 2}
.bc-4{grid-column:span 2}
.bc-5{grid-column:span 2;background:#16a34a;border-color:#16a34a}
.bc-6{grid-column:span 6;background:#facc15;border-color:#facc15;padding:1.5rem 2rem;display:flex;align-items:center;gap:3rem}
.bc-num{
  font-family:var(--fr);font-style:italic;
  font-size:4rem;line-height:1;
  color:rgba(124,58,237,0.25);margin-bottom:0.5rem;
  font-weight:900;
}
.bc-2 .bc-num,.bc-5 .bc-num{color:rgba(255,255,255,0.2)}
.bc-6 .bc-num{color:rgba(9,9,11,0.15);font-size:3rem;margin:0}
.bc-deg{
  font-family:var(--fr);font-weight:900;
  font-size:1.1rem;color:var(--wh);line-height:1.2;margin-bottom:0.3rem;
}
.bc-2 .bc-deg,.bc-5 .bc-deg{color:#fff}
.bc-6 .bc-deg{color:var(--bk);font-size:1rem}
.bc-school{
  font-family:var(--mo);font-size:10px;letter-spacing:0.08em;
  color:rgba(255,255,255,0.45);
}
.bc-2 .bc-school{color:rgba(255,255,255,0.7)}
.bc-5 .bc-school{color:rgba(255,255,255,0.7)}
.bc-6 .bc-school{color:rgba(9,9,11,0.55)}
.bc-yr{
  font-family:var(--mo);font-size:9px;letter-spacing:0.1em;
  color:rgba(255,255,255,0.3);margin-top:0.4rem;
}
.bc-6 .bc-yr{color:rgba(9,9,11,0.4)}
.bc-badge{
  display:inline-block;background:var(--bk);color:var(--ye);
  font-family:var(--mo);font-size:8px;padding:3px 7px;
  letter-spacing:0.1em;margin-top:0.5rem;
}

/* ── PUBLICATIONS — DIAGONAL SPLIT ── */
.pub-section{
  padding:6rem 3rem;
  background:linear-gradient(135deg, #0f0a1e 50%, #0e1a0e 50%);
  position:relative;
}
.pub-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem}
.pub-col-head{
  font-family:var(--mo);font-size:10px;letter-spacing:0.2em;
  color:var(--pu2);padding-bottom:1rem;
  border-bottom:1px solid rgba(124,58,237,0.3);margin-bottom:0;
}
.pub-col-head.green{color:var(--gr2);border-color:rgba(22,163,74,0.3)}
.pub-entry{
  padding:1.1rem 0;border-bottom:1px solid rgba(255,255,255,0.05);
  transition:padding-left 0.2s;cursor:default;
}
.pub-entry:hover{padding-left:0.5rem}
.pub-entry:hover .pe-t{color:var(--pu2)}
.pub-col:last-child .pub-entry:hover .pe-t{color:var(--gr2)}
.pe-t{
  font-family:var(--fr);font-style:italic;
  font-size:0.95rem;color:rgba(255,255,255,0.8);
  line-height:1.4;transition:color 0.2s;margin-bottom:0.2rem;
}
.pe-v{font-family:var(--mo);font-size:9px;color:rgba(255,255,255,0.28);letter-spacing:0.05em}
.pe-y{font-family:var(--mo);font-size:9px;color:var(--pu2);letter-spacing:0.12em;margin-top:0.2rem;font-weight:400}
.pub-col:last-child .pe-y{color:var(--gr2)}

/* ── EXPERIENCE — HORIZONTAL SCROLL CARDS ── */
.xp-section{padding:6rem 3rem;background:#09090b;overflow:hidden}
.xp-scroll-wrap{overflow-x:auto;padding-bottom:1rem;cursor:grab;user-select:none}
.xp-scroll-wrap::-webkit-scrollbar{height:2px}
.xp-scroll-wrap::-webkit-scrollbar-track{background:rgba(255,255,255,0.05)}
.xp-scroll-wrap::-webkit-scrollbar-thumb{background:var(--pu)}
.xp-cards{display:flex;gap:16px;width:max-content;padding-bottom:0.5rem}
.xp-card{
  width:340px;flex-shrink:0;
  background:#18181b;border:1px solid rgba(124,58,237,0.18);
  padding:2.5rem 2rem;
  position:relative;overflow:hidden;
  transition:border-color 0.2s;
}
.xp-card:hover{border-color:var(--pu)}
.xp-card::before{
  content:'';
  position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--pu);
}
.xp-card.green::before{background:var(--gr)}
.xp-card.yellow::before{background:var(--ye)}
.xp-date{font-family:var(--mo);font-size:9px;letter-spacing:0.15em;color:var(--pu2);margin-bottom:0.8rem}
.xp-card.green .xp-date{color:var(--gr2)}
.xp-card.yellow .xp-date{color:var(--ye)}
.xp-role{
  font-family:var(--fr);font-weight:900;
  font-size:1.3rem;line-height:1.1;color:var(--wh);margin-bottom:0.3rem;
}
.xp-org{font-family:var(--mo);font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:0.06em;margin-bottom:1rem}
.xp-pts{display:flex;flex-direction:column;gap:0.4rem}
.xp-pt{font-size:0.83rem;color:rgba(255,255,255,0.55);font-family:var(--fr);font-style:italic;line-height:1.5;display:flex;gap:0.6rem}
.xp-pt::before{content:'→';color:var(--pu);font-size:11px;flex-shrink:0;font-style:normal;margin-top:2px}
.xp-card.green .xp-pt::before{color:var(--gr2)}
.xp-card.yellow .xp-pt::before{color:var(--ye)}
.xp-drag-hint{
  font-family:var(--mo);font-size:9px;letter-spacing:0.15em;
  color:rgba(255,255,255,0.25);margin-top:1rem;display:flex;align-items:center;gap:0.5rem;
}
.xp-drag-hint::before{content:'← drag →'}

/* ── TALKS — NUMBERED LIST ── */
.talks-section{
  padding:6rem 3rem;
  background:#0f0a1e;
  position:relative;overflow:hidden;
}
.talks-bg-num{
  position:absolute;font-family:var(--fr);font-size:40vw;font-weight:900;
  font-style:italic;color:rgba(124,58,237,0.04);
  right:-5vw;top:50%;transform:translateY(-50%);
  pointer-events:none;user-select:none;line-height:1;
}
.talks-list{display:flex;flex-direction:column;position:relative;z-index:1}
.talk-row{
  display:grid;grid-template-columns:80px 1fr auto;gap:2rem;
  padding:1.8rem 0;border-bottom:1px solid rgba(124,58,237,0.12);
  transition:background 0.2s,padding-left 0.2s;cursor:default;
}
.talk-row:hover{background:rgba(124,58,237,0.06);padding-left:0.75rem}
.talk-n{
  font-family:var(--fr);font-style:italic;font-size:2.5rem;
  color:rgba(168,85,247,0.2);line-height:1;
  transition:color 0.2s;
}
.talk-row:hover .talk-n{color:var(--pu2)}
.talk-t{
  font-family:var(--fr);font-style:italic;
  font-size:1rem;color:rgba(255,255,255,0.8);
  line-height:1.45;margin-bottom:0.25rem;
}
.talk-v{font-family:var(--mo);font-size:9px;color:rgba(255,255,255,0.3);letter-spacing:0.06em}
.talk-yr{
  font-family:var(--mo);font-size:10px;
  color:var(--pu2);letter-spacing:0.1em;
  white-space:nowrap;padding-top:0.4rem;
}

/* ── RESEARCH — INTERACTIVE TAG CLOUD ── */
.research-section{padding:6rem 3rem;background:var(--pu);position:relative;overflow:hidden}
.research-bg{
  position:absolute;font-family:var(--fr);font-size:32vw;font-weight:900;
  font-style:italic;color:rgba(255,255,255,0.04);
  bottom:-5vh;right:-3vw;pointer-events:none;user-select:none;line-height:1;
}
.tag-cloud{display:flex;flex-wrap:wrap;gap:0.7rem;position:relative;z-index:1}
.rtag{
  font-family:var(--mo);font-size:11px;letter-spacing:0.08em;
  padding:0.55rem 1.2rem;
  border:1.5px solid rgba(255,255,255,0.3);
  color:rgba(255,255,255,0.7);background:transparent;
  cursor:pointer;transition:all 0.18s;
}
.rtag:hover,.rtag.active{
  background:#fff;color:var(--pu);border-color:#fff;
  transform:scale(1.05);
}
.rtag.featured{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.5);color:#fff}
.rtag.featured:hover,.rtag.featured.active{background:#fff;color:var(--pu)}

/* ── SKILLS + AWARDS — TWO PANELS ── */
.bottom-panels{display:grid;grid-template-columns:1fr 1fr;min-height:60vh}
.panel-skills{background:#18181b;padding:5rem 3rem;border-right:1px solid rgba(124,58,237,0.2)}
.panel-awards{background:#09090b;padding:5rem 3rem}
.panel-title{
  font-family:var(--fr);font-weight:900;font-size:2.5rem;
  color:var(--wh);line-height:0.95;margin-bottom:2.5rem;
}
.panel-title em{font-style:italic;font-weight:300;color:var(--pu2)}
.skill-group{margin-bottom:2rem}
.sg-head{
  font-family:var(--mo);font-size:9px;letter-spacing:0.2em;
  color:var(--pu);border-bottom:1px solid rgba(124,58,237,0.3);
  padding-bottom:0.5rem;margin-bottom:0.7rem;
}
.sg-item{
  font-family:var(--fr);font-size:0.9rem;color:rgba(255,255,255,0.55);
  padding:0.3rem 0;display:flex;align-items:center;gap:0.6rem;
}
.sg-item::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--pu2);flex-shrink:0}
.award-list{display:flex;flex-direction:column;gap:1rem}
.award-card{
  padding:1.2rem 1.5rem;border:1px solid rgba(255,255,255,0.06);
  border-left:3px solid var(--pu);
  transition:border-left-color 0.2s,background 0.2s;cursor:default;
}
.award-card:hover{border-left-color:var(--ye);background:rgba(250,204,21,0.04)}
.award-t{
  font-family:var(--sy);font-size:0.88rem;font-weight:700;
  color:var(--wh);margin-bottom:0.2rem;letter-spacing:0.01em;
}
.award-m{font-family:var(--mo);font-size:9px;color:rgba(255,255,255,0.35);letter-spacing:0.04em}

/* ── CONTACT — FULL BLEED ── */
.contact-section{
  min-height:60vh;display:grid;grid-template-columns:1fr 1fr;
  border-top:1px solid rgba(124,58,237,0.3);
}
.contact-left{
  background:var(--pu);padding:6rem 4rem;
  display:flex;flex-direction:column;justify-content:space-between;
  position:relative;overflow:hidden;
}
.contact-left-bg{
  position:absolute;font-family:var(--fr);font-style:italic;font-weight:900;
  font-size:25vw;color:rgba(255,255,255,0.06);
  bottom:-0.1em;right:-0.05em;line-height:1;pointer-events:none;
}
.contact-h{
  font-family:var(--fr);font-weight:900;
  font-size:clamp(3.5rem,6vw,7rem);line-height:0.9;
  color:#fff;position:relative;z-index:1;
}
.contact-h em{font-weight:300;font-style:italic;color:var(--ye)}
.contact-quote{
  font-family:var(--fr);font-style:italic;font-weight:300;
  font-size:1.1rem;color:rgba(255,255,255,0.6);
  max-width:340px;line-height:1.8;position:relative;z-index:1;
}
.contact-right{
  background:#0f0a1e;padding:6rem 4rem;
  display:flex;flex-direction:column;justify-content:center;gap:1.5rem;
}
.c-field{display:flex;flex-direction:column;gap:4px;padding:1.2rem;border:1px solid rgba(124,58,237,0.15);transition:border-color 0.2s}
.c-field:hover{border-color:rgba(124,58,237,0.5)}
.c-lbl{font-family:var(--mo);font-size:8px;letter-spacing:0.22em;color:var(--pu2)}
.c-val{font-family:var(--fr);font-size:1rem;color:rgba(255,255,255,0.7);font-style:italic}
.contact-cta{
  display:inline-block;align-self:flex-start;
  background:var(--ye);color:var(--bk);
  font-family:var(--mo);font-size:10px;letter-spacing:0.16em;
  padding:0.9rem 2rem;
  transition:background 0.2s,transform 0.15s;
}
.contact-cta:hover{background:#fff;transform:translateY(-2px)}

/* ── FOOTER ── */
footer{
  background:var(--bk);border-top:2px solid var(--pu);
  padding:1.5rem 3rem;display:flex;justify-content:space-between;align-items:center;
}
.f-sig{font-family:var(--fr);font-style:italic;font-weight:300;font-size:1rem;color:rgba(255,255,255,0.3)}
.f-meta{font-family:var(--mo);font-size:9px;letter-spacing:0.14em;color:rgba(255,255,255,0.18)}

/* ── SECTION HEADERS ── */
.sec-head{display:flex;align-items:baseline;gap:1.5rem;margin-bottom:3rem}
.sec-label{font-family:var(--mo);font-size:9px;letter-spacing:0.22em;color:var(--pu2)}
.sec-label.gr{color:var(--gr2)}
.sec-label.ye{color:var(--ye)}
.sec-label.wh{color:rgba(255,255,255,0.5)}
.sec-title{
  font-family:var(--fr);font-weight:900;
  font-size:clamp(2.5rem,5vw,5rem);
  line-height:0.92;color:var(--wh);
}
.sec-title em{font-style:italic;font-weight:300}
.sec-title.bk{color:var(--bk)}
.sec-rule{flex:1;height:1px;background:rgba(255,255,255,0.08)}
.sec-rule.pu{background:rgba(124,58,237,0.4)}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

@media(max-width:960px){
  nav{padding:0 1.5rem}.nav-links{display:none}
  .hero{grid-template-columns:1fr}.hero-right{display:none}
  .hero-left{padding:5rem 1.5rem 4rem}
  .bento-grid{grid-template-columns:1fr 1fr}.bc-1{grid-column:span 2}.bc-6{grid-column:span 2;flex-direction:column;gap:1rem}
  .pub-grid,.bottom-panels,.contact-section{grid-template-columns:1fr}
  .bento,.pub-section,.xp-section,.talks-section,.research-section,.bottom-panels .panel-skills,.bottom-panels .panel-awards,.contact-section .contact-left,.contact-section .contact-right{padding:4rem 1.5rem}
  footer{padding:1.5rem;flex-direction:column;gap:0.4rem;text-align:center}
}
</style>
</head>
<body>

<div class="cursor-glow" id="glow"></div>

<!-- NAV -->
<nav>
  <span class="nav-logo">Priscila <span>Schilaro</span> Santa Rosa</span>
  <ul class="nav-links">
    <li><a href="#edu">Education</a></li>
    <li><a href="#pub">Publications</a></li>
    <li><a href="#xp">Experience</a></li>
